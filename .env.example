# ──────────────────────────────────────────────
# OPTION A: Use OpenAI (cloud)
# ──────────────────────────────────────────────
#OPENAI_API_KEY=your_openai_api_key_here
#MODEL_NAME=gpt-4o
# LLM_BASE_URL=   ← leave blank or omit entirely

# ──────────────────────────────────────────────
# OPTION B: Use LM Studio (local, no API key needed)
# 1. Open LM Studio → Local Server tab → Start Server
# 2. Load any model (e.g. Llama-3, Mistral, Phi-3)
# 3. Set the values below and comment out OPENAI_API_KEY
# ──────────────────────────────────────────────
OPENAI_API_KEY=lm-studio
LLM_BASE_URL=http://localhost:1234/v1
MODEL_NAME=#← use the exact model name shown in LM Studio

# ──────────────────────────────────────────────
# Shared settings (same for both options)
# ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2
